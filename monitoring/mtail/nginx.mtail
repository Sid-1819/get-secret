counter requests_total by status, method
counter bytes_sent_total
histogram request_latency_seconds buckets 0.005, 0.01, 0.025, 0.05, 0.1, 0.25, 0.5, 1, 2.5, 5, 10

/"([A-Z]+) [^"]*" (\d{3}) (\d+)/ {
    requests_total[$2][$1]++
    bytes_sent_total += int($3)
}

/rt=([0-9.]+)/ {
    request_latency_seconds = float($1)
}
